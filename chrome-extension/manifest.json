{
  "manifest_version": 3,
  "name": "Pushpa Agent",
  "version": "2.0.0",
  "description": "Pushpa browser automation agent — gives your Pushpa workspace full control over this browser session.",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "webNavigation",
    "scripting",
    "declarativeNetRequest",
    "debugger",
    "sessions",
    "alarms"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:3001/*",
      "https://Pushpa.ai/*",
      "https://*.Pushpa.ai/*",
      "https://app.Pushpa.ai/*"
    ]
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "declarative_net_request": {
    "rule_resources": [{
      "id": "strip_frame_headers",
      "enabled": true,
      "path": "rules/strip_frame_headers.json"
    }]
  },

  "web_accessible_resources": [
    {
      "resources": ["lib/*", "handlers/*", "rules/*", "content/sovereign-scanner.js", "content/OverlayManager.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}

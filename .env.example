# BuyDecision AI - Environment Variables
# Copy this file to .env.local and fill in your values

# ── App Configuration ────────────────────────────────────────────────────────

# App URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# ── AI Model Providers ────────────────────────────────────────────────────────

# Moonshot AI (Kimi) - https://platform.moonshot.cn/
# Get your API key from: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=your_moonshot_api_key_here

# NVIDIA NIM (Alternative) - https://build.nvidia.com/
# Get your API key from: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=your_nvidia_api_key_here

# Anthropic Claude (Optional) - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Stripe Payments (99¢/100 credits) ───────────────────────────────────────

# Stripe Secret Key - https://dashboard.stripe.com/
# Test key starts with sk_test_, live key starts with sk_live_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Price ID for 99¢/100 credits
# Create a product in Stripe Dashboard → Products → Add Product
# Price should be $0.99 for 100 credits
STRIPE_PRICE_ID=price_your_price_id_here

# Stripe Webhook Secret (for payment confirmation)
# Set up webhook in Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Jina AI Reader (Web scraping) ───────────────────────────────────────────

# Jina Reader API - https://jina.ai/
# Free tier available, get key from: https://jina.ai/api-dashboard/
JINA_API_KEY=your_jina_api_key_here

# ── CoinGecko (Crypto prices - FREE, no key needed) ────────────────────────

# CoinGecko API is free for basic usage
# No API key needed for public endpoints
# Optional: Get Pro key for higher rate limits: https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=your_coingecko_pro_key_here

# ── App Configuration ────────────────────────────────────────────────────────

# App URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# ── Credits Configuration ────────────────────────────────────────────────────

# Credits per purchase
CREDITS_PER_PURCHASE=100

# Price per purchase (in cents)
PRICE_PER_PURCHASE=99

# Credits consumed per analysis
CREDITS_PER_ANALYSIS=2

# ── Production Checklist ──────────────────────────────────────────────────────
# □ Add MOONSHOT_API_KEY or NVIDIA_API_KEY
# □ Configure Stripe keys and create $0.99 product
# □ Add JINA_API_KEY for web research
# □ Set NEXT_PUBLIC_APP_URL to your production domain
# □ Run: npm run build (verify no errors)
# □ Deploy to Vercel/your hosting provider
